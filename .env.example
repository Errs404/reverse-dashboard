# Reverse Dashboard production example
SECRET_KEY=change-this-to-a-long-random-secret
DASHBOARD_NAME=Reverse Dashboard
REVERSE_DASHBOARD_DATA=/opt/reverse-dashboard/data
HOST_ROOT=/
FILES_READ_ONLY=1
ENABLE_DOCKER=1
ENABLE_PM2=1
ENABLE_NGINX=1
ENABLE_BACKUP=1
ENABLE_TERMINAL=1
ENABLE_GDRIVE_BACKUP=1
GDRIVE_REMOTE=
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_STAGING=0
BACKUP_DIR=/opt/reverse-dashboard/data/backups
